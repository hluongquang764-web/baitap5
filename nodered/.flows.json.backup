    },
    {
        "id": "4c8113f14aeffbb9",
        "type": "function",
        "z": "134204dac66e986e",
        "name": "Set SQL query",
        "func": "msg.topic = \"UPDATE petrol_price SET price = CASE fuel_type \" +\n  \"WHEN 'RON95-III' THEN \" + msg.payload['RON95-III'] + \" \" +\n  \"WHEN 'RON92-II' THEN \" + msg.payload['RON92-II'] + \" \" +\n  \"WHEN 'DO 0.05S' THEN \" + msg.payload['DO 0.05S'] + \" \" +\n  \"END WHERE fuel_type IN ('RON95-III','RON92-II','DO 0.05S')\";\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 920,
        "y": 280,
        "wires": [
            [
                "mysql1"
            ]
        ]
    },
    {
        "id": "tg_check",
        "type": "function",
        "z": "134204dac66e986e",
        "name": "Kiểm tra ngưỡng alert",
        "func": "var p = msg.payload;\nvar LOW  = { 'RON95-III':20000, 'RON92-II':19000, 'DO 0.05S':18000 };\nvar HIGH = { 'RON95-III':25000, 'RON92-II':24000, 'DO 0.05S':23000 };\nvar alerts = [];\nObject.keys(p).forEach(function(k){\n  if(p[k] > 0 && p[k] < LOW[k])  alerts.push('🔵 ' + k + ': ' + p[k].toLocaleString() + ' ₫ — DƯỚI NGƯỠNG THẤP (< ' + LOW[k].toLocaleString() + ')');\n  if(p[k] > HIGH[k]) alerts.push('🔴 ' + k + ': ' + p[k].toLocaleString() + ' ₫ — VƯỢT NGƯỠNG CAO (> ' + HIGH[k].toLocaleString() + ')');\n});\nif(alerts.length > 0){\n  msg.payload = {\n    chatId: -5251862594,\n    type: 'message',\n    content: '⛽ CẢNH BÁO GIÁ XĂNG DẦU\\n' + alerts.join('\\n') + '\\n⏰ ' + new Date().toLocaleString('vi-VN')\n  };\n  return msg;\n}\nreturn null;",
        "outputs": 1,
        "x": 1080,
        "y": 680,
        "wires": [
            [
                "tg_sender"
            ]
        ]
    },
