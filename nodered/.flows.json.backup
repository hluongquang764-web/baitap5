    },
    {
        "id": "influx1",
        "type": "function",
        "z": "134204dac66e986e",
        "name": "Ghi InfluxDB",
        "func": "var fields = msg.payload;\nvar lines = [];\nObject.keys(fields).forEach(function(k) {\n  lines.push('petrol_price,fuel_type=' + k.replace(/ /g,'\\\\ ') + ' price=' + fields[k]);\n});\nmsg.payload = lines.join('\\n');\nmsg.headers = {\n  'Authorization': 'Token my-super-secret-token-bt5',\n  'Content-Type': 'text/plain; charset=utf-8'\n};\nmsg.url = 'http://bt5-influxdb:8086/api/v2/write?org=tnut&bucket=petrol_history&precision=s';\nreturn msg;",
        "outputs": 1,
        "x": 1050,
        "y": 560,
        "wires": [
            [
                "influxhttp1"
            ]
        ]
    },
    {
        "id": "influxhttp1",
        "type": "http request",
        "z": "134204dac66e986e",
        "name": "POST InfluxDB",
        "method": "POST",
        "ret": "txt",
        "paytoqs": "ignore",
        "url": "",
        "tls": "",
        "persist": false,
        "x": 1280,
        "y": 540,
        "wires": [
