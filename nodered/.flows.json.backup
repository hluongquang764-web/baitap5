    {
        "id": "func1",
        "type": "function",
        "z": "134204dac66e986e",
        "name": "Parse giá xăng",
        "func": "msg.payload = {\n  'RON95-III': 19000,\n  'RON92-II':  20310,\n  'DO 0.05S':  19910\n};\nmsg.prices = msg.payload;\nreturn msg;",
